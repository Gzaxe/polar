  {
   "kind": 2,
   "value": "(*首先输入或者明确矩阵形式，然后尝试拆分，ee部分和gg部分就加起来，所以不用管*)\r\n(*激发态的减少*)\r\n(*总的自发辐射系数Gmsa，g1e的是Gms1和g2e的Gms2*)\r\n(*Gmsa=Gms1+Gms2;\r\nGms1=2;\r\nGms2=3;*)\r\n(*激发态减少Sme的矩阵形式*)\r\nSme=-Gmsa*DiagonalMatrix[{rhoe1e1,rhoe2e2,0,0,0,0,0,0}];\r\n(*基态对角元的增加Smgd*)\r\nSmgd=DiagonalMatrix[{0,0,3/2*Gms1*Delta[1/2,1/2,1/2,1/2]*rhoe1e1*Delta[1/2,1/2,1/2,1/2]+3/2*Gms1*Delta[1/2,1/2,1/2,-1/2]*rhoe2e2*Delta[1/2,-1/2,1/2,1/2],3/2*Gms1*(Delta[1/2,-1/2,1/2,1/2]*rhoe1e1*Delta[1/2,1/2,1/2,-1/2]+Delta[1/2,-1/2,1/2,-1/2]*rhoe2e2*Delta[1/2,-1/2,1/2,-1/2]),3/2*Gms2*(Delta[3/2,3/2,1/2,1/2]*rhoe1e1*Delta[1/2,1/2,3/2,3/2]),3/2*Gms2*(Delta[3/2,1/2,1/2,1/2]*rhoe1e1*Delta[1/2,1/2,3/2,1/2]+Delta[3/2,1/2,1/2,-1/2]*rhoe2e2*Delta[1/2,-1/2,3/2,1/2]),3/2*Gms2*(Delta[3/2,-1/2,1/2,1/2]*rhoe1e1*Delta[1/2,1/2,3/2,-1/2]+Delta[3/2,-1/2,1/2,-1/2]*rhoe2e2*Delta[1/2,-1/2,3/2,-1/2]),3/2*Gms2*(Delta[3/2,-3/2,1/2,-1/2]*rhoe2e2*Delta[1/2,-1/2,3/2,-3/2])}];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {
    "timing": {
     "startTime": 1781486340383,
     "endTime": 1781486340547
    },
    "executionOrder": 18,
    "success": true
   }
  },
  {
   "kind": 2,
   "value": "(*拆分对角元*)\r\nrhot={{rhoe1e1,rhoe1e2,rhoe1g11,rhoe1g12,rhoe1g21,rhoe1g22,rhoe1g23,rhoe1g24},{rhoe2e1,rhoe2e2,rhoe2g11,rhoe2g12,rhoe2g21,rhoe2g22,rhoe2g23,rhoe2g24},{rhog11e1,rhog11e2,rhog11g11,rhog11g12,rhog11g21,rhog11g22,rhog11g23,rhog11g24},{rhog12e1,rhog12e2,rhog12g11,rhog12g12,rhog12g21,rhog12g22,rhog12g23,rhog12g24},{rhog21e1,rhog21e2,rhog21g11,rhog21g12,rhog21g21,rhog21g22,rhog21g23,rhog21g24},{rhog22e1,rhog22e2,rhog22g11,rhog22g12,rhog22g21,rhog22g22,rhog22g23,rhog22g24},{rhog23e1,rhog23e2,rhog23g11,rhog23g12,rhog23g21,rhog23g22,rhog23g23,rhog23g24},{rhog24e1,rhog24e2, rhog24g11, rhog24g12, rhog24g21, rhog24g22, rhog24g23, rhog24g24}};\r\n(*激发态部分*)\r\nGmsat=DiagonalMatrix[{Gmsa, Gmsa, 0, 0, 0, 0, 0, 0}];\r\nSmet=-Gmsat*rhot;\r\n(*基态部分*)",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {
    "timing": {
     "startTime": 1781486390665,
     "endTime": 1781486390941
    },
    "executionOrder": 20,
    "success": true
   }
  },
  {
   "kind": 2,
   "value": "(*d指导给了一个新思路，我们的目标不是把上面的矩阵拆分成矩阵乘法，而是让mma能够识别出rho是一个矩阵，也就是说把上面的耗散项变成rho作为矩阵的函数也能一样的实现*)\r\nSme2[rho_] := -Gmsa * DiagonalMatrix[{rho[[1,1]], rho[[2,2]], 0,0,0,0,0,0}];\r\nSmgd2[rho_] :=DiagonalMatrix[{0,0,2/3*Gms1*Delta[1/2,1/2,1/2,1/2]*rho[[1,1]]*Delta[1/2,1/2,1/2,1/2]+2/3*Gms1*Delta[1/2,1/2,1/2,-1/2]*rho[[2,2]]*Delta[1/2,-1/2,1/2,1/2],2/3*Gms1*(Delta[1/2,-1/2,1/2,1/2]*rho[[1,1]]*Delta[1/2,1/2,1/2,-1/2]+Delta[1/2,-1/2,1/2,-1/2]*rho[[2,2]]*Delta[1/2,-1/2,1/2,-1/2]),2/3*Gms2*(Delta[3/2,3/2,1/2,1/2]*rho[[1,1]]*Delta[1/2,1/2,3/2,3/2]),2/3*Gms2*(Delta[3/2,1/2,1/2,1/2]*rho[[1,1]]*Delta[1/2,1/2,3/2,1/2]+Delta[3/2,1/2,1/2,-1/2]*rho[[2,2]]*Delta[1/2,-1/2,3/2,1/2]),2/3*Gms2*(Delta[3/2,-1/2,1/2,1/2]*rho[[1,1]]*Delta[1/2,1/2,3/2,-1/2]+Delta[3/2,-1/2,1/2,-1/2]*rho[[2,2]]*Delta[1/2,-1/2,3/2,-1/2]),2/3*Gms2*(Delta[3/2,-3/2,1/2,-1/2]*rho[[2,2]]*Delta[1/2,-1/2,3/2,-3/2])}];",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {
    "timing": {
     "startTime": 1781488447864,
     "endTime": 1781488448025
    },
    "executionOrder": 26,
