  {
   "kind": 2,
   "value": "(*基态部分*)\r\n(*首先是Δ的矩阵形式*)\r\nDeltaMat12={{Delta[1/2,1/2,1/2,1/2],Delta[1/2,1/2,1/2,-1/2]},{Delta[1/2,-1/2,1/2,1/2],Delta[1/2,-1/2,1/2,-1/2]},{0,0},{0,0},{0,0},{0,0}};\r\nDeltaMat12d={{Delta[1/2,1/2,1/2,1/2],Delta[1/2,1/2,1/2,-1/2],0,0,0,0},{Delta[1/2,-1/2,1/2,1/2],Delta[1/2,-1/2,1/2,-1/2],0,0,0,0}};\r\nDeltaMat32={{0,0},{0,0},{Delta[3/2,3/2,1/2,1/2],0},{Delta[3/2,1/2,1/2,1/2],Delta[3/2,1/2,1/2,-1/2]},{Delta[3/2,-1/2,1/2,1/2],Delta[3/2,-1/2,1/2,-1/2]},{0,Delta[3/2,-3/2,1/2,-1/2]}};\r\nDeltaMat32d={{0,0,Delta[1/2,1/2,3/2,3/2],Delta[1/2,1/2,3/2,1/2],Delta[1/2,1/2,3/2,-1/2],0},{0,0,0,Delta[1/2,-1/2,3/2,1/2],Delta[1/2,-1/2,3/2,-1/2],Delta[1/2,-1/2,3/2,-3/2]}};\r\nrhoee={{Subscript[\\[Rho], 1, 1],Subscript[\\[Rho], 1, 2]},{Subscript[\\[Rho], 2, 1],Subscript[\\[Rho], 2, 2]}};",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {
    "timing": {
     "startTime": 1781510096506,
     "endTime": 1781510096860
    },
    "executionOrder": 7,
    "success": true
   }
  },
  {
   "kind": 2,
   "value": "(*组合出gg部分*)\r\nSmgd=2/3*Gms1*DeltaMat12.rhoee.DeltaMat12d+2/3*Gms2*DeltaMat32.rhoee.DeltaMat32d;",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {
    "timing": {
     "startTime": 1781510871880,
     "endTime": 1781510871954
    },
    "executionOrder": 12,
    "success": true
   }
  },
  {
   "kind": 2,
   "value": "SmgdFull = ArrayFlatten[{\r\n   {ConstantArray[0, {2, 2}], ConstantArray[0, {2, 6}]},\r\n   {ConstantArray[0, {6, 2}], Smgd}\r\n}];",
