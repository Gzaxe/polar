  {
   "kind": 2,
   "value": "(*resolSe[10, 0, 0, 1, 0, 0, 0, 0, 0]*)\r\n rho0t[0, 0, 1, 0, 0, 0, 0, 0]",
   "languageId": "wolfram",
   "outputs": [
