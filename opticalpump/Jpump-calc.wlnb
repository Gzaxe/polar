  {
   "kind": 2,
   "value": "(*check \r\ntrho = Array[Subscript[\\[Rho], #1, #2] &, {8, 8}];\r\nSimplify[Tr[Smtotal[trho]]]*)",
   "languageId": "wolfram",
   "outputs": [
    {
     "items": [
      {
       "data": "<div class=\"wexpr\"><wrow><w></w><wrow><w></w><wb>(</wb><wrow><w></w><w>Gms1</w><w>+</w><w>Gms2</w><w>-</w><w>Gmsa</w></wrow><wb>)</wb></wrow><w></w><wrow><w></w><wb>(</wb><wrow><w></w><wsub><w></w><w>ρ</w><w><wrow><w></w><w>1</w><w>,</w><w>1</w></wrow></w></wsub><w>+</w><wsub><w></w><w>ρ</w><w><wrow><w></w><w>2</w><w>,</w><w>2</w></wrow></w></wsub></wrow><wb>)</wb></wrow></wrow></div>",
       "mime": "x-application/wolfram-language-html"
      },
      {
       "data": "(Gms1 + Gms2 - Gmsa)*(Subscript[ρ, 1, 1] + Subscript[ρ, 2, 2])",
       "mime": "text/plain"
