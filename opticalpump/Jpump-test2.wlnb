   }
  },
  {
   "kind": 2,
   "value": "Smgdt2[rho_] := Module[{rhoee, smgd6, smgdFull},\r\n   rhoee = rho[[1 ;; 2, 1 ;; 2]];   (* 提取激发态子块 *)\r\n   smgd6 = 2/3 * Gms1 * (DeltaMat12 . rhoee . DeltaMat12d) +\r\n           2/3 * Gms2 * (DeltaMat32 . rhoee . DeltaMat32d);\r\n   smgdFull = ConstantArray[0, {8, 8}];\r\n   smgdFull[[3 ;; 8, 3 ;; 8]] = smgd6;\r\n   smgdFull\r\n];\r\nSmgdt2[rho]",
