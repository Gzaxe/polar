  {
   "kind": 2,
   "value": "DeltaD[1/2,1/2,1/2,-1/2]",
   "languageId": "wolfram",
   "outputs": [
    {
     "items": [
      {
       "data": "<div class=\"wexpr\"><wsup><w></w><wrow><w></w><wb>(</wb><wrow><w></w><w>-</w><w>1</w></wrow><wb>)</wb></wrow><w><wrow style=\"font-family:&quot;Helvetica&quot;;\"><w></w><w>†</w></wrow></w></wsup></div>",
       "mime": "x-application/wolfram-language-html"
